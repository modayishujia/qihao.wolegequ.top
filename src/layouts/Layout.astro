---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  canonical?: string;
  type?: 'website' | 'article';
}

const { title, description, lang = 'zh', canonical, type } = Astro.props;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : lang} class:list={[{ dark: false }]}>
  <head>
    <SEOHead title={title} description={description} lang={lang} canonical={canonical} type={type} />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
    <script is:inline>
      (function() {
        var path = window.location.pathname;
        var langPrefixes = ['en', 'ja', 'de', 'pt', 'fr'];
        var isLangPage = langPrefixes.some(function(p) {
          return path === '/' + p + '/' || path.startsWith('/' + p + '/');
        });
        if (isLangPage) return;
        if (sessionStorage.getItem('lang_redirect_done')) return;

        var saved = localStorage.getItem('preferred_lang');
        if (saved && saved !== 'zh' && langPrefixes.indexOf(saved) !== -1) {
          sessionStorage.setItem('lang_redirect_done', '1');
          var target = saved + '/' + path;
          window.location.replace('/' + target);
          return;
        }

        var browserLang = (navigator.language || navigator.userLanguage || '').toLowerCase().split('-')[0];
        if (browserLang && browserLang !== 'zh' && langPrefixes.indexOf(browserLang) !== -1) {
          localStorage.setItem('preferred_lang', browserLang);
          sessionStorage.setItem('lang_redirect_done', '1');
          var target2 = browserLang + '/' + path;
          window.location.replace('/' + target2);
        }
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
