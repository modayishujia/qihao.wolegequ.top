---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title: string;
  description: string;
  lang?: 'zh' | 'en';
  canonical?: string;
  type?: 'website' | 'article';
}

const { title, description, lang = 'zh', canonical, type } = Astro.props;
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'} class:list={[{ dark: false }]}>
  <head>
    <SEOHead title={title} description={description} lang={lang} canonical={canonical} type={type} />
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
