---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = '起号指南' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="各赛道起号逻辑与运营指南" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6979809011861753" crossorigin="anonymous"></script>
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
