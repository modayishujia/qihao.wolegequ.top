---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import NicheCard from '../../components/NicheCard.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const niches = (await getCollection('niches-fr'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="Guide de Croissance - Stratégies de Niche" description="Stratégies de croissance par niche — positionnement, planification de contenu, croissance d'abonnés et monétisation. 16 niches couvrant tech, IA, beauté, fitness et plus." lang="fr" canonical="https://qihao.wolegequ.top/fr/">
  <div class="flex min-h-screen">
    <Sidebar niches={niches} lang="fr" />

    <main class="lg:ml-64 flex-1 min-h-screen">
      <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 lg:py-24">
        <h2 class="text-3xl lg:text-4xl font-bold text-[var(--color-text-primary)] mb-4">De Zéro à Un — Méthodologie de Croissance</h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mb-6">
          Stratégies de croissance par niche — positionnement, planification de contenu, croissance d'abonnés et monétisation. Choisissez une niche et lancez votre parcours de créateur.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">{niches.length} Niches</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">Testé</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">Mis à jour chaque semaine</span>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-10">
        <div class="rounded-xl border border-[var(--color-accent)] bg-[var(--color-accent-subtle)] p-6 lg:p-8">
          <div class="flex flex-col md:flex-row items-center gap-4 mb-4">
            <span class="text-4xl">🚀</span>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-[var(--color-accent)]">Kit de Croissance</h3>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">Obtenez la méthodologie complète de croissance — positionnement, planification, croissance d'abonnés et stratégies de monétisation.</p>
            </div>
            <a href="https://github.com/modayishujia/wolegequ.skill" target="_blank" rel="noopener noreferrer" class="px-5 py-2 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
              En savoir plus
            </a>
          </div>
          <div class="bg-[var(--color-bg-primary)] rounded-lg p-4 font-mono text-sm">
            <p class="text-[var(--color-text-secondary)] mb-2"># Copiez ce prompt à l'IA pour installer le kit de croissance</p>
            <code class="text-[var(--color-accent)]">Veuillez installer ce skill : https://github.com/modayishujia/wolegequ.skill</code>
          </div>
        </div>
      </section>

      <div class="max-w-5xl mx-auto px-6 lg:px-8 pb-6">
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-6979809011861753" data-ad-slot="auto" data-ad-format="horizontal" data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {niches.map((niche) => (
            <NicheCard title={niche.data.title} icon={niche.data.icon} description={niche.data.description} slug={niche.id} lang="fr" />
          ))}
        </div>
      </section>

      <Footer lang="fr" />
    </main>
  </div>
</Layout>
