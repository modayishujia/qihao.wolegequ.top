---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import NicheCard from '../../components/NicheCard.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const niches = (await getCollection('niches-de'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="Konto-Wachstumsleitfaden - Nischenstrategien" description="Wachstumsstrategien für verschiedene Nischen — Positionierung, Content-Planung, Follower-Wachstum und Monetarisierung. 16 Nischen von Tech über AI bis Beauty." lang="de" canonical="https://qihao.wolegequ.top/de/">
  <div class="flex min-h-screen">
    <Sidebar niches={niches} lang="de" />

    <main class="lg:ml-64 flex-1 min-h-screen">
      <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 lg:py-24">
        <h2 class="text-3xl lg:text-4xl font-bold text-[var(--color-text-primary)] mb-4">Von Null zu Eins — Wachstumsmethodik</h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mb-6">
          Wachstumsstrategien für verschiedene Nischen — Positionierung, Content-Planung, Follower-Wachstum und Monetarisierung. Wähle eine Nische und starte deine Kreatoren-Reise.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">{niches.length} Nischen</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">Getestet</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">Wöchentlich aktualisiert</span>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-10">
        <div class="rounded-xl border border-[var(--color-accent)] bg-[var(--color-accent-subtle)] p-6 lg:p-8">
          <div class="flex flex-col md:flex-row items-center gap-4 mb-4">
            <span class="text-4xl">🚀</span>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-[var(--color-accent)]">Wachstums-Toolkit</h3>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">Erhalte die vollständige Wachstumsmethodik — Positionierung, Content-Planung, Follower-Wachstum und Monetarisierungsstrategien.</p>
            </div>
            <a href="https://github.com/modayishujia/wolegequ.skill" target="_blank" rel="noopener noreferrer" class="px-5 py-2 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
              Mehr erfahren
            </a>
          </div>
          <div class="bg-[var(--color-bg-primary)] rounded-lg p-4 font-mono text-sm">
            <p class="text-[var(--color-text-secondary)] mb-2"># Kopiere diesen Prompt an KI, um das Wachstums-Toolkit zu installieren</p>
            <code class="text-[var(--color-accent)]">Bitte installiere dieses Skill: https://github.com/modayishujia/wolegequ.skill</code>
          </div>
        </div>
      </section>

      <div class="max-w-5xl mx-auto px-6 lg:px-8 pb-6">
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-6979809011861753" data-ad-slot="auto" data-ad-format="horizontal" data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {niches.map((niche) => (
            <NicheCard title={niche.data.title} icon={niche.data.icon} description={niche.data.description} slug={niche.id} lang="de" />
          ))}
        </div>
      </section>

      <Footer lang="de" />
    </main>
  </div>
</Layout>
