---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import NicheCard from '../components/NicheCard.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const niches = (await getCollection('niches'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="起号指南 - 各赛道起号逻辑与运营策略" description="汇集各赛道起号核心逻辑，包含定位策略、内容规划、涨粉技巧和变现路径。覆盖数码、科技、AI、摄影、生活方式、知识付费等16个赛道。" lang="zh">
  <div class="flex min-h-screen">
    <Sidebar niches={niches} lang="zh" />

    <main class="lg:ml-64 flex-1 min-h-screen">
      <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 lg:py-24">
        <h2 class="text-3xl lg:text-4xl font-bold text-[var(--color-text-primary)] mb-4">从零到一的起号方法论</h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mb-6">
          汇集各赛道起号核心逻辑，包含定位策略、内容规划、涨粉技巧和变现路径。选择你感兴趣的赛道，开始你的内容创作之旅。
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">{niches.length} 个赛道</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">实战验证</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">持续更新</span>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-10">
        <div class="rounded-xl border border-[var(--color-accent)] bg-[var(--color-accent-subtle)] p-6 lg:p-8">
          <div class="flex flex-col md:flex-row items-center gap-4 mb-4">
            <span class="text-4xl">🚀</span>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-[var(--color-accent)]">起号技能包</h3>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">一键获取起号全流程方法论，包含定位策略、内容规划、涨粉技巧和变现路径，助你快速起号。</p>
            </div>
            <a href="https://github.com/modayishujia/wolegequ.skill" target="_blank" rel="noopener noreferrer" class="px-5 py-2 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
              查看详情
            </a>
          </div>
          <div class="bg-[var(--color-bg-primary)] rounded-lg p-4 font-mono text-sm">
            <p class="text-[var(--color-text-secondary)] mb-2"># 复制以下 prompt 给 AI，一键安装起号技能包</p>
            <code class="text-[var(--color-accent)]">请安装这个 skill：https://github.com/modayishujia/wolegequ.skill</code>
          </div>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-10">
        <h3 class="text-xl font-bold text-[var(--color-text-primary)] mb-4">常用 Prompts</h3>
        <p class="text-sm text-[var(--color-text-secondary)] mb-6">安装起号技能包后，复制以下 prompt 即可快速生成各类内容：</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <div class="flex items-center gap-2 mb-2">
              <span>📝</span>
              <span class="font-medium text-[var(--color-text-primary)]">生成文章</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              用AI赛道的skill，帮我写一篇关于「AI工具提效」的深度文章，要求2000字，包含3个实操案例
            </div>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <div class="flex items-center gap-2 mb-2">
              <span>💬</span>
              <span class="font-medium text-[var(--color-text-primary)]">微博文案</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              用美妆赛道的skill，帮我写5条微博文案，主题是「平价护肤」，要有互动引导
            </div>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <div class="flex items-center gap-2 mb-2">
              <span>📕</span>
              <span class="font-medium text-[var(--color-text-primary)]">小红书文案</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              用健身赛道的skill，帮我写一篇小红书笔记，主题「居家健身一周瘦5斤」，要有爆款标题
            </div>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <div class="flex items-center gap-2 mb-2">
              <span>🎙️</span>
              <span class="font-medium text-[var(--color-text-primary)]">口播脚本</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              用数码赛道的skill，帮我写一个60秒口播脚本，主题「百元耳机测评」，前3秒要抓人
            </div>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 md:col-span-2">
            <div class="flex items-center gap-2 mb-2">
              <span>🎬</span>
              <span class="font-medium text-[var(--color-text-primary)]">分镜脚本</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              用美食赛道的skill，帮我写一个30秒短视频分镜脚本，主题「10分钟做一道硬菜」，包含画面描述、台词、时长
            </div>
          </div>
        </div>
      </section>

      <div class="max-w-5xl mx-auto px-6 lg:px-8 pb-6">
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-6979809011861753" data-ad-slot="auto" data-ad-format="horizontal" data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {niches.map((niche) => (
            <NicheCard title={niche.data.title} icon={niche.data.icon} description={niche.data.description} slug={niche.id} lang="zh" />
          ))}
        </div>
      </section>

      <Footer lang="zh" />
    </main>
  </div>
</Layout>
