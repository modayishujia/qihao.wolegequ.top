---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import NicheCard from '../../components/NicheCard.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const niches = (await getCollection('niches-ja'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="アカウント成長ガイド - ニッチ戦略と成長テクニック" description="ニッチ別の成長戦略：ポジショニング、コンテンツ企画、フォロワー獲得、収益化。テック、AI、美容、フィットネスなど16ニッチを網羅。" lang="ja" canonical="https://qihao.wolegequ.top/ja/">
  <div class="flex min-h-screen">
    <Sidebar niches={niches} lang="ja" />

    <main class="lg:ml-64 flex-1 min-h-screen">
      <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 lg:py-24">
        <h2 class="text-3xl lg:text-4xl font-bold text-[var(--color-text-primary)] mb-4">ゼロから始める成長方法論</h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mb-6">
          ニッチ別の成長戦略：ポジショニング、コンテンツ企画、フォロワー獲得、収益化。興味のあるニッチを選んで、クリエイタージャーニーを始めましょう。
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">{niches.length} ニッチ</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">実績済み</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">毎週更新</span>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-10">
        <div class="rounded-xl border border-[var(--color-accent)] bg-[var(--color-accent-subtle)] p-6 lg:p-8">
          <div class="flex flex-col md:flex-row items-center gap-4 mb-4">
            <span class="text-4xl">🚀</span>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-[var(--color-accent)]">成長スキルパック</h3>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">アカウント成長の全プロセスをワンクリックで取得。ポジショニング戦略、コンテンツ企画、フォロワー獲得、収益化を網羅。</p>
            </div>
            <a href="https://github.com/modayishujia/wolegequ.skill" target="_blank" rel="noopener noreferrer" class="px-5 py-2 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
              詳細を見る
            </a>
          </div>
          <div class="bg-[var(--color-bg-primary)] rounded-lg p-4 font-mono text-sm">
            <p class="text-[var(--color-text-secondary)] mb-2"># AIに以下のプロンプトをコピーして成長スキルパックをインストール</p>
            <code class="text-[var(--color-accent)]">このスキルをインストールしてください：https://github.com/modayishujia/wolegequ.skill</code>
          </div>
        </div>
      </section>

      <div class="max-w-5xl mx-auto px-6 lg:px-8 pb-6">
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-6979809011861753" data-ad-slot="auto" data-ad-format="horizontal" data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {niches.map((niche) => (
            <NicheCard title={niche.data.title} icon={niche.data.icon} description={niche.data.description} slug={niche.id} lang="ja" />
          ))}
        </div>
      </section>

      <Footer lang="ja" />
    </main>
  </div>
</Layout>
