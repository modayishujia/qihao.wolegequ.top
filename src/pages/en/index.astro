---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import NicheCard from '../../components/NicheCard.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const niches = (await getCollection('niches-en'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout title="Account Growth Guide - Niche Strategies" description="Core growth strategies across niches — positioning, content planning, audience growth, and monetization. 16 niches covering tech, AI, beauty, fitness, and more." lang="en" canonical="https://qihao.wolegequ.top/en/">
  <div class="flex min-h-screen">
    <Sidebar niches={niches} lang="en" />

    <main class="lg:ml-64 flex-1 min-h-screen">
      <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 lg:py-24">
        <h2 class="text-3xl lg:text-4xl font-bold text-[var(--color-text-primary)] mb-4">From Zero to One</h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mb-6">
          Core growth strategies across niches — positioning, content planning, audience growth, and monetization. Pick a niche and start your creator journey.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">{niches.length} Niches</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">Battle-tested</span>
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-subtle)] text-[var(--color-accent)] text-xs font-medium">Updated Weekly</span>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-10">
        <div class="rounded-xl border border-[var(--color-accent)] bg-[var(--color-accent-subtle)] p-6 lg:p-8">
          <div class="flex flex-col md:flex-row items-center gap-4 mb-4">
            <span class="text-4xl">🚀</span>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-[var(--color-accent)]">Account Growth Toolkit</h3>
              <p class="text-sm text-[var(--color-text-secondary)] mt-1">Get the complete account growth methodology — positioning, content planning, audience growth, and monetization strategies to accelerate your growth.</p>
            </div>
            <a href="https://github.com/modayishujia/wolegequ.skill" target="_blank" rel="noopener noreferrer" class="px-5 py-2 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
              Learn More
            </a>
          </div>
          <div class="bg-[var(--color-bg-primary)] rounded-lg p-4 font-mono text-sm">
            <p class="text-[var(--color-text-secondary)] mb-2"># Copy this prompt to AI to install the growth toolkit</p>
            <code class="text-[var(--color-accent)]">Please install this skill: https://github.com/modayishujia/wolegequ.skill</code>
          </div>
        </div>
      </section>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-10">
        <h3 class="text-xl font-bold text-[var(--color-text-primary)] mb-4">Ready-to-Use Prompts</h3>
        <p class="text-sm text-[var(--color-text-secondary)] mb-6">After installing the skill, copy these prompts to generate content instantly:</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <div class="flex items-center gap-2 mb-2">
              <span>📝</span>
              <span class="font-medium text-[var(--color-text-primary)]">Article</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              Using the AI niche skill, write a 2000-word in-depth article about "AI productivity tools" with 3 practical case studies
            </div>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <div class="flex items-center gap-2 mb-2">
              <span>💬</span>
              <span class="font-medium text-[var(--color-text-primary)]">Weibo Post</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              Using the beauty niche skill, write 5 Weibo posts about "budget skincare" with engagement hooks
            </div>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <div class="flex items-center gap-2 mb-2">
              <span>📕</span>
              <span class="font-medium text-[var(--color-text-primary)]">Xiaohongshu Note</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              Using the fitness niche skill, write a Xiaohongshu post about "lose 5kg in a week with home workouts" with a viral title
            </div>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4">
            <div class="flex items-center gap-2 mb-2">
              <span>🎙️</span>
              <span class="font-medium text-[var(--color-text-primary)]">Voice-over Script</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              Using the tech niche skill, write a 60-second voice-over script for "budget earbuds review" with a hook in the first 3 seconds
            </div>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-4 md:col-span-2">
            <div class="flex items-center gap-2 mb-2">
              <span>🎬</span>
              <span class="font-medium text-[var(--color-text-primary)]">Storyboard Script</span>
            </div>
            <div class="bg-[var(--color-bg-primary)] rounded p-3 font-mono text-xs text-[var(--color-text-secondary)]">
              Using the food niche skill, write a 30-second short video storyboard for "cook a fancy dish in 10 minutes" including shot descriptions, dialogue, and timing
            </div>
          </div>
        </div>
      </section>

      <div class="max-w-5xl mx-auto px-6 lg:px-8 pb-6">
        <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-6979809011861753" data-ad-slot="auto" data-ad-format="horizontal" data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <section class="max-w-5xl mx-auto px-6 lg:px-8 pb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {niches.map((niche) => (
            <NicheCard title={niche.data.title} icon={niche.data.icon} description={niche.data.description} slug={niche.id} lang="en" />
          ))}
        </div>
      </section>

      <Footer lang="en" />
    </main>
  </div>
</Layout>
