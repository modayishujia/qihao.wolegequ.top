---
interface Props {
  nicheTitle: string;
  slug: string;
}

const { nicheTitle, slug } = Astro.props;
---

<div class="prompt-tool rounded-xl border border-[var(--color-accent)] bg-[var(--color-accent-subtle)] p-6 mt-10">
  <div class="flex items-center gap-2 mb-3">
    <span class="text-2xl">⚡</span>
    <h3 class="text-lg font-bold text-[var(--color-accent)]">一键生成 {nicheTitle} 爆款 Prompt</h3>
  </div>
  <p class="text-sm text-[var(--color-text-secondary)] mb-4">输入一句话描述你想做的事，AI 将为你生成该赛道专属的爆款 Prompt，直接复制给 AI 即可使用。</p>

  <div class="flex flex-col gap-3">
    <input
      type="text"
      id={`prompt-input-${slug}`}
      class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-primary)] text-[var(--color-text-primary)] placeholder:text-[var(--color-text-tertiary)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition-colors text-sm"
      placeholder={`例如：写一篇关于${nicheTitle}的爆款文章`}
      data-niche={nicheTitle}
      data-slug={slug}
    />
    <button
      id={`prompt-btn-${slug}`}
      class="self-start px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors cursor-pointer"
      data-niche={nicheTitle}
      data-slug={slug}
    >
      生成 Prompt
    </button>
  </div>

  <div id={`prompt-result-${slug}`} class="hidden mt-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-[var(--color-accent)]">生成的 Prompt</span>
      <button
        id={`prompt-copy-${slug}`}
        class="copy-btn px-3 py-1 rounded text-xs font-medium border border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-colors cursor-pointer"
        data-target={`prompt-output-${slug}`}
      >
        📋 一键复制
      </button>
    </div>
    <div
      id={`prompt-output-${slug}`}
      class="bg-[var(--color-bg-primary)] rounded-lg p-4 font-mono text-sm text-[var(--color-text-secondary)] leading-relaxed whitespace-pre-wrap select-all border border-[var(--color-border)]"
    ></div>
  </div>

  <div id={`prompt-copied-${slug}`} class="hidden mt-2 text-xs text-green-500 font-medium">✅ 已复制到剪贴板！</div>
</div>

<script>
  function copyToClipboard(text: string): Promise<void> {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    document.execCommand('copy');
    document.body.removeChild(textarea);
    return Promise.resolve();
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[id^="prompt-btn-"]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const slug = (btn as HTMLElement).dataset.slug!;
        const input = (document.getElementById(`prompt-input-${slug}`) as HTMLInputElement)?.value?.trim();

        if (!input) {
          const inputEl = document.getElementById(`prompt-input-${slug}`) as HTMLInputElement;
          inputEl.placeholder = `请输入一句话描述你想做的事...`;
          inputEl.focus();
          return;
        }

        const resultEl = document.getElementById(`prompt-result-${slug}`);
        const outputEl = document.getElementById(`prompt-output-${slug}`);
        const copiedEl = document.getElementById(`prompt-copied-${slug}`);
        const btnEl = btn as HTMLButtonElement;

        btnEl.disabled = true;
        btnEl.textContent = 'AI 生成中…';
        if (resultEl) resultEl.classList.add('hidden');

        try {
          const res = await fetch('/api/generate', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug, input }),
          });
          const data = await res.json();
          if (data.success) {
            if (outputEl) outputEl.textContent = data.prompt;
            if (resultEl) resultEl.classList.remove('hidden');
            if (copiedEl) copiedEl.classList.add('hidden');
          } else {
            if (outputEl) outputEl.textContent = '生成失败：' + (data.error || '未知错误');
            if (resultEl) resultEl.classList.remove('hidden');
          }
        } catch (e) {
          if (outputEl) outputEl.textContent = '网络错误，请稍后重试。';
          if (resultEl) resultEl.classList.remove('hidden');
        }

        btnEl.disabled = false;
        btnEl.textContent = '生成 Prompt';
      });
    });

    document.querySelectorAll('[id^="prompt-input-"]').forEach((input) => {
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const slug = (input as HTMLElement).dataset.slug!;
          const btn = document.getElementById(`prompt-btn-${slug}`);
          if (btn) btn.click();
        }
      });
    });

    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const targetId = (btn as HTMLElement).dataset.target!;
        const outputEl = document.getElementById(targetId);
        const slug = targetId.replace('prompt-output-', '');
        const copiedEl = document.getElementById(`prompt-copied-${slug}`);

        if (outputEl) {
          await copyToClipboard(outputEl.textContent || '');
          if (copiedEl) {
            copiedEl.classList.remove('hidden');
            setTimeout(() => copiedEl.classList.add('hidden'), 2000);
          }
          const originalText = btn.textContent;
          btn.textContent = '✅ 已复制';
          setTimeout(() => { btn.textContent = originalText; }, 1500);
        }
      });
    });
  });
</script>
