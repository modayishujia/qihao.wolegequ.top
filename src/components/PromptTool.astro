  function getTemplate(slug: string): string {
    return PROMPT_TEMPLATES[slug] || PROMPT_TEMPLATES['default'];
  }

  function generatePrompt(slug: string, input: string): string {
    const template = getTemplate(slug);
    return template.replace('{input}', input);
  }

  function copyToClipboard(text: string): Promise<void> {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text);
    }
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    document.execCommand('copy');
    document.body.removeChild(textarea);
    return Promise.resolve();
  }

  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[id^="prompt-btn-"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const slug = (btn as HTMLElement).dataset.slug!;
        const niche = (btn as HTMLElement).dataset.niche!;
        const input = (document.getElementById(`prompt-input-${slug}`) as HTMLInputElement)?.value?.trim();

        if (!input) {
          const inputEl = document.getElementById(`prompt-input-${slug}`) as HTMLInputElement;
          inputEl.placeholder = `请输入一句话描述你想做的事...`;
          inputEl.focus();
          return;
        }

        const result = generatePrompt(slug, input);
        const outputEl = document.getElementById(`prompt-output-${slug}`);
        const resultEl = document.getElementById(`prompt-result-${slug}`);
        const copiedEl = document.getElementById(`prompt-copied-${slug}`);

        if (outputEl) outputEl.textContent = result;
        if (resultEl) resultEl.classList.remove('hidden');
        if (copiedEl) copiedEl.classList.add('hidden');
      });
    });

    document.querySelectorAll('[id^="prompt-input-"]').forEach((input) => {
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          const slug = (input as HTMLElement).dataset.slug!;
          const btn = document.getElementById(`prompt-btn-${slug}`);
          if (btn) btn.click();
        }
      });
    });

    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const targetId = (btn as HTMLElement).dataset.target!;
        const outputEl = document.getElementById(targetId);
        const slug = targetId.replace('prompt-output-', '');
        const copiedEl = document.getElementById(`prompt-copied-${slug}`);

        if (outputEl) {
          await copyToClipboard(outputEl.textContent || '');
          if (copiedEl) {
            copiedEl.classList.remove('hidden');
            setTimeout(() => copiedEl.classList.add('hidden'), 2000);
          }
          const originalText = btn.textContent;
          btn.textContent = '✅ 已复制';
          setTimeout(() => { btn.textContent = originalText; }, 1500);
        }
      });
    });
  });
</script>
