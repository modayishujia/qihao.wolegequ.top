---
interface Props {
  nicheTitle: string;
  slug: string;
}

const { nicheTitle, slug } = Astro.props;
---

<div class="prompt-tool rounded-xl border border-[var(--color-accent)] bg-[var(--color-accent-subtle)] p-6 mt-10">
  <div class="flex items-center gap-2 mb-3">
    <span class="text-2xl">⚡</span>
    <h3 class="text-lg font-bold text-[var(--color-accent)]">一键生成 {nicheTitle} 爆款 Prompt</h3>
  </div>
  <p class="text-sm text-[var(--color-text-secondary)] mb-4">输入一句话描述你想做的事，AI 将为你生成该赛道专属的爆款 Prompt，直接复制给 AI 即可使用。</p>

  <div class="flex flex-col gap-3">
    <input
      type="text"
      id={`prompt-input-${slug}`}
      class="w-full px-4 py-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-primary)] text-[var(--color-text-primary)] placeholder:text-[var(--color-text-tertiary)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition-colors text-sm"
      placeholder={`例如：写一篇关于${nicheTitle}的爆款文章`}
      data-niche={nicheTitle}
      data-slug={slug}
    />
    <button
      id={`prompt-btn-${slug}`}
      class="self-start px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors cursor-pointer"
      data-niche={nicheTitle}
      data-slug={slug}
    >
      生成 Prompt
    </button>
  </div>

  <div id={`prompt-result-${slug}`} class="hidden mt-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-[var(--color-accent)]">生成的 Prompt</span>
      <button
        id={`prompt-copy-${slug}`}
        class="copy-btn px-3 py-1 rounded text-xs font-medium border border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-colors cursor-pointer"
        data-target={`prompt-output-${slug}`}
      >
        📋 一键复制
      </button>
    </div>
    <div
      id={`prompt-output-${slug}`}
      class="bg-[var(--color-bg-primary)] rounded-lg p-4 font-mono text-sm text-[var(--color-text-secondary)] leading-relaxed whitespace-pre-wrap select-all border border-[var(--color-border)]"
    ></div>
  </div>

  <div id={`prompt-copied-${slug}`} class="hidden mt-2 text-xs text-green-500 font-medium">✅ 已复制到剪贴板！</div>
</div>

<script>
