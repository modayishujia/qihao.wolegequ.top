---
interface Props {
  lang: 'zh' | 'en';
  currentSlug?: string | null;
}

const { lang, currentSlug = null } = Astro.props;
const targetLang = lang === 'zh' ? 'en' : 'zh';
let href = targetLang === 'en' ? '/en/' : '/';
if (currentSlug) {
  href = targetLang === 'en' ? `/en/${currentSlug}` : `/${currentSlug}`;
}
---

<a
  href={href}
  class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-hover)] transition-colors"
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
  </svg>
  <span>{lang === 'zh' ? 'EN' : '中文'}</span>
</a>
