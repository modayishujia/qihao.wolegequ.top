---
interface Props {
  title: string;
  description: string;
  lang: 'zh' | 'en';
  canonical?: string;
  type?: 'website' | 'article';
}

const { title, description, lang, canonical = Astro.url.href, type = 'website' } = Astro.props;
const site = 'https://qihao.wolegequ.top';
const zhUrl = canonical.replace('/en/', '/').replace(site + '/en', site);
const enUrl = canonical.includes('/en/') ? canonical : canonical.replace(site, site + '/en');
const locale = lang === 'zh' ? 'zh_CN' : 'en_US';
const altLocale = lang === 'zh' ? 'en_US' : 'zh_CN';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={canonical} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={locale} />
<meta property="og:locale:alternate" content={altLocale} />
<meta property="og:site_name" content={lang === 'zh' ? '起号指南' : 'Account Growth Guide'} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@iGaves" />

<link rel="alternate" hreflang="zh" href={zhUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={zhUrl} />

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": type === 'article' ? 'Article' : 'WebSite',
  "name": lang === 'zh' ? '起号指南' : 'Account Growth Guide',
  "url": site,
  "description": description,
  "inLanguage": [lang === 'zh' ? 'zh-CN' : 'en'],
})} />

<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6979809011861753" crossorigin="anonymous"></script>
<title>{title}</title>
